# Step 3: Fit Mixture Models and Test Hypotheses

## 3.1 Maximum Likelihood Mixture Model

```{r fit-mixture}
nll_mix3p <- function(par, errors, nt_errors) {
  kp <- exp(par[1]); pt <- plogis(par[2])
  ps <- plogis(par[3]) * (1 - pt); pg <- 1 - pt - ps
  
  ll_t <- suppressWarnings(dvonmises(circular(errors), circular(0), kp))
  ll_s <- rowMeans(sapply(1:ncol(nt_errors), function(j)
    suppressWarnings(dvonmises(circular(errors - nt_errors[,j]), circular(0), kp))))
  ll_g <- 1 / (2*pi)
  
  ll <- pt * ll_t + ps * ll_s + pg * ll_g
  ll[ll <= 0] <- 1e-10
  -sum(log(ll))
}

ml_results <- sim_data %>%
  group_by(subject, condition, efficiency_z) %>%
  summarise(err = list(recall_error), nt = list(cbind(nt1, nt2, nt3)), .groups = "drop") %>%
  mutate(fit = map2(err, nt, ~{
    tryCatch({
      r <- optim(c(log(5), qlogis(.65), qlogis(.3)), nll_mix3p,
                 errors = .x, nt_errors = .y, method = "Nelder-Mead")
      tibble(kappa = exp(r$par[1]), p_target = plogis(r$par[2]),
             p_swap = plogis(r$par[3]) * (1-plogis(r$par[2])),
             p_guess = 1 - plogis(r$par[2]) - plogis(r$par[3])*(1-plogis(r$par[2])))
    }, error = function(e) tibble(kappa=NA, p_target=NA, p_swap=NA, p_guess=NA))
  })) %>% unnest(fit)
```

## 3.2 H2a: κ ~ Processing Efficiency × Distractor

```{r h2a-test}
h2a <- lm(kappa ~ efficiency_z * condition, data = ml_results)
summary(h2a)$coefficients %>%
  as.data.frame() %>% rownames_to_column("Term") %>%
  kable(digits = 3, caption = "H2a: Precision (κ) Model") %>%
  kable_styling(bootstrap_options = c("striped"), full_width = FALSE)
```

## 3.3 H2b: p~swap~ ~ Processing Efficiency × Distractor

```{r h2b-test}
h2b <- lm(p_swap ~ efficiency_z * condition, data = ml_results)
summary(h2b)$coefficients %>%
  as.data.frame() %>% rownames_to_column("Term") %>%
  kable(digits = 3, caption = "H2b: Swap Errors Model") %>%
  kable_styling(bootstrap_options = c("striped"), full_width = FALSE)
```

## 3.4 Visualization

```{r h2-plots, fig.height=5, fig.width=12}
p1 <- ggplot(ml_results, aes(efficiency_z, kappa, color = condition)) +
  geom_point(alpha = .5) + geom_smooth(method = "lm", se = TRUE) +
  scale_color_manual(values = c("#27AE60","#E74C3C"),
                     labels = c("15° Distractor","No Distractor")) +
  labs(title = "H2a: κ ~ Efficiency", x = "Processing Efficiency (z)", y = "κ") +
  theme_minimal(base_size = 13) +
  theme(plot.title = element_text(face = "bold"), legend.position = "bottom")

p2 <- ggplot(ml_results, aes(efficiency_z, p_swap, color = condition)) +
  geom_point(alpha = .5) + geom_smooth(method = "lm", se = TRUE) +
  scale_color_manual(values = c("#27AE60","#E74C3C"),
                     labels = c("15° Distractor","No Distractor")) +
  labs(title = "H2b: p(swap) ~ Efficiency", x = "Processing Efficiency (z)", y = "p(swap)") +
  theme_minimal(base_size = 13) +
  theme(plot.title = element_text(face = "bold"), legend.position = "bottom")

p1 + p2 + plot_layout(guides = "collect") & theme(legend.position = "bottom")
```


# Step 2: Simulate Retro-Cue Continuous Recall Data

## 2.1 Generate Trial-Level Data

Each trial produces a recall error drawn from a 3-component mixture: von Mises (target), von Mises (swap to non-target), or Uniform (guess).

```{r simulate-trials}
N_sub <- 60; N_trials <- 80; set_size <- 4

eff_z <- ac_scores$efficiency_z[1:N_sub]

simulate_trials <- function(sub_id, eff) {
  map_dfr(c("no_dist", "dist_15"), function(cond) {
    if (cond == "no_dist") {
      kp <- 8; pt <- 0.70; ps <- 0.15
    } else {
      kp <- max(1, 5 + eff * 2); pt <- 0.60; ps <- max(0.01, 0.25 + eff * -0.08)
    }
    pg <- max(0.01, 1 - pt - ps)
    probs <- c(pt, ps, pg) / sum(c(pt, ps, pg))
    
    map_dfr(1:N_trials, function(t) {
      tgt <- runif(1, -pi, pi)
      nts <- runif(set_size - 1, -pi, pi)
      type <- sample(c("target","swap","guess"), 1, prob = probs)
      
      resp <- switch(type,
        target = as.numeric(rvonmises(1, circular(tgt), kp)),
        swap   = as.numeric(rvonmises(1, circular(sample(nts, 1)), kp)),
        guess  = runif(1, -pi, pi)
      )
      err <- ((resp - tgt + pi) %% (2*pi)) - pi
      
      tibble(subject = sub_id, condition = cond, distractor = as.integer(cond == "dist_15"),
             recall_error = err, error_deg = err * 180/pi,
             nt1 = nts[1]-tgt, nt2 = nts[2]-tgt, nt3 = nts[3]-tgt,
             efficiency_z = eff)
    })
  })
}

sim_data <- map2_dfr(1:N_sub, eff_z, simulate_trials)
```

## 2.2 Recall Error Distributions

```{r error-distributions, fig.height=5}
